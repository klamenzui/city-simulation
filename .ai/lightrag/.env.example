# Copy this file to .env and fill in real provider settings.
# Do not commit .env because it may contain API keys.

HOST=127.0.0.1
PORT=9621
WORKSPACE=city-sim
WORKING_DIR=./rag_storage
INPUT_DIR=./inputs

# Document indexing behavior.
SUMMARY_LANGUAGE=German
ENABLE_LLM_CACHE_FOR_EXTRACT=true
MAX_PARALLEL_INSERT=2
MAX_ASYNC=4
TIMEOUT=150

# OpenAI-compatible LLM example. Leave keys empty in this template.
LLM_BINDING=openai
LLM_MODEL=
LLM_BINDING_HOST=https://api.openai.com/v1
LLM_BINDING_API_KEY=

# OpenAI-compatible embedding example. Choose dimensions to match the model.
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=
EMBEDDING_DIM=
EMBEDDING_BINDING_HOST=https://api.openai.com/v1
EMBEDDING_BINDING_API_KEY=

# Local Ollama example.
# LLM_BINDING=ollama
# LLM_MODEL=llama3.1:8b
# LLM_BINDING_HOST=http://localhost:11434
# EMBEDDING_BINDING=ollama
# EMBEDDING_MODEL=bge-m3:latest
# EMBEDDING_DIM=1024
# EMBEDDING_BINDING_HOST=http://localhost:11434

# Optional API protection. Set both API key and auth accounts for real protection.
# LIGHTRAG_API_KEY=
# WHITELIST_PATHS=/health
# AUTH_ACCOUNTS=
# TOKEN_SECRET=
# TOKEN_EXPIRE_HOURS=48
